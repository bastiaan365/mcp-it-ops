{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read(./**)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(rg *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git branch *)",
      "Bash(git show *)",
      "Bash(git stash list)",
      "Bash(python -m py_compile *)",
      "Bash(python3 -m py_compile *)",
      "Bash(.venv/bin/python -m py_compile *)",
      "Bash(.venv/bin/python -m pytest *)",
      "Bash(.venv/bin/python -c *)",
      "Bash(.venv/bin/pip list*)",
      "Bash(.venv/bin/pip show *)",
      "Bash(ruff *)",
      "Bash(black --check *)",
      "Bash(mypy *)",
      "Bash(python -m json.tool *)",
      "Bash(python3 -m json.tool *)"
    ],
    "ask": [
      "Write(./**)",
      "Edit(./**)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git switch *)",
      "Bash(git restore *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(git rebase *)",
      "Bash(git cherry-pick *)",
      "Bash(.venv/bin/pip install *)",
      "Bash(pip install *)",
      "Bash(.venv/bin/python -m mcp *)",
      "Bash(mcp dev *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./config/settings.yaml)",
      "Read(./secrets/**)",
      "Read(./.git/config)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.npmrc)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(curl * | *sh*)",
      "Bash(wget * | *sh*)",
      "Bash(git push *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)",
      "Bash(git clean -fd*)",
      "Bash(git branch -D *)",
      "Bash(gh release *)",
      "Bash(gh repo delete *)",
      "Bash(.venv/bin/python -m mcp_it_ops*)",
      "Bash(python -m mcp_it_ops*)",
      "Bash(mcp-it-ops)"
    ]
  }
}
